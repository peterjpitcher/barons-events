NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=BaronsHub <noreply@auth.orangejelly.co.uk>
BOOKING_RESEND_FROM_EMAIL=Barons Pub Company <noreply@auth.orangejelly.co.uk>

# Customer booking emails are enabled by default when RESEND_API_KEY is set.
# Set to "true" only if paid booking confirmations/refund emails must stop.
BOOKING_EMAILS_DISABLED=

# Wider BaronsHub operational emails (event submitted, review decisions,
# debrief reminders, SLT digest, todo digest, etc.) are opt-in. Set to "true"
# in environments that should send staff workflow emails.
BARONSHUB_OPERATIONAL_EMAILS_ENABLED=

# Legacy kill-switch for operational emails. Auth emails (invite, password
# reset) and booking communications use separate controls.
NOTIFICATIONS_DISABLED=
BARONSHUB_WEBSITE_API_KEY=

# Signs customer booking amendment links. Required in production.
# Generate with: openssl rand -hex 32
BOOKING_UPDATE_TOKEN_SECRET=

# App base URL — used in invite and password-reset email links (redirectTo)
# Set to the deployed domain (e.g. https://baronshub.orangejelly.co.uk)
# Falls back to VERCEL_URL (set automatically by Vercel) or the hardcoded default
NEXT_PUBLIC_SITE_URL=

# OpenAI — used for generating UK sporting events in the inspiration pipeline
OPENAI_API_KEY=
OPENAI_WEBSITE_COPY_MODEL=gpt-4o-mini

# Secures the Vercel cron endpoint — set a long random string in production
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Phase B′/B″ event reliability flag. Set to "true" after the linked
# save_event_draft / submit_event_for_review / propose_event_draft migrations
# are applied and the create/edit/submit/propose flows have been smoked.
#
# Leave this OFF (blank or "false"). It is off in production, and local
# environments should match so bugs reproduce. Note .env.local.docker is
# gitignored and historically set this to "true", which meant the RPC path
# ran locally but never in production. If you have an old copy, set it to
# false. Before turning this on anywhere, confirm the RPCs authorise against
# the 'manager' role: migration 20260723110000 repaired them, since they
# previously checked the retired 'office_worker' value and rejected everyone.
EVENT_SAVE_USE_RPC=

# Twilio SMS — used for booking confirmations, reminders, and post-event messages
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_URL=

# Stripe Checkout — used for paid public event bookings. Server-side only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare Turnstile CAPTCHA (required on login and forgot-password)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
