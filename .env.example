NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=BaronsHub <no-reply@yourdomain.com>
BARONSHUB_WEBSITE_API_KEY=

# App base URL — used in invite and password-reset email links (redirectTo)
# Set to the deployed domain (e.g. https://baronshub.orangejelly.co.uk)
# Falls back to VERCEL_URL (set automatically by Vercel) or the hardcoded default
NEXT_PUBLIC_SITE_URL=

# OpenAI — used for generating UK sporting events in the inspiration pipeline
OPENAI_API_KEY=
OPENAI_WEBSITE_COPY_MODEL=gpt-4o-mini

# Secures the Vercel cron endpoint — set a long random string in production
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Twilio SMS — used for booking confirmations, reminders, and post-event messages
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Cloudflare Turnstile CAPTCHA (required on login and forgot-password)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
